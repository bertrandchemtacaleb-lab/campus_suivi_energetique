# Base de données
DATABASE_URL=postgresql+psycopg://scip_user:scip_password@localhost:5432/scip_db

# Sécurité
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API météo
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=scip/campus

# Modbus
MODBUS_HOST=localhost
MODBUS_PORT=502

# Mode de fonctionnement des données : "simulated" ou "real"
DATA_SOURCE_MODE=simulated
